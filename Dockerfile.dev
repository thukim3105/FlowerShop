# Development container image
FROM node:20-alpine

WORKDIR /app

# Copy package config and install deps
COPY package*.json ./
RUN npm install

# Copy source for initial context
COPY . .

EXPOSE 5173

# Start Vite in host mode so host can connect
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]

